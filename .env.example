# ── Provider ──────────────────────────────────────────────────
# "ai-studio" (default) — free, easy setup
# "vertex-ai"           — uses GCP billing / Free Credits
GEMINI_PROVIDER=ai-studio

# ── AI Studio ─────────────────────────────────────────────────
# Get from https://aistudio.google.com/apikey (format: AIzaSy...)
GEMINI_API_KEY=your_api_key_here

# ── Vertex AI ─────────────────────────────────────────────────
# Uncomment and set these when using GEMINI_PROVIDER=vertex-ai
# GEMINI_API_KEY=your_gcp_api_key_here
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1

# ── Model ─────────────────────────────────────────────────────
# AI Studio Gemini models (use generateContent API):
#   gemini-2.0-flash-exp-image-generation  — free, experimental (default)
#   gemini-2.0-flash-preview-image-generation — preview
#
# Vertex AI Imagen models (use predict API):
#   imagen-3.0-generate-002  — high quality, uses GCP credits
#   imagen-3.0-fast-generate-001 — faster, lower cost
GEMINI_MODEL=gemini-2.0-flash-exp-image-generation

# ── Output ────────────────────────────────────────────────────
# IMAGE_OUTPUT_DIR=/absolute/path/to/output
