# Required: Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model for image generation (default: gemini-2.0-flash-exp-image-generation)
# Available models:
#   gemini-2.0-flash-exp-image-generation  (experimental, widely available)
#   gemini-3.1-flash-image-preview         (Nano Banana 2, higher quality, requires paid tier)
#   gemini-3-pro-image-preview             (Nano Banana Pro, best quality, requires paid tier)
GEMINI_MODEL=gemini-2.0-flash-exp-image-generation

# Optional: Output directory for saved images (default: ./output)
IMAGE_OUTPUT_DIR=/absolute/path/to/output
